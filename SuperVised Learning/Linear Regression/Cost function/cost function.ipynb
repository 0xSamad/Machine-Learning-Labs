   "source": [
    "def cost_function(x,y,w,b):\n",
    "    total_cost = 0\n",
    "    m = x[0].shape\n",
    "    for i in range(m):\n",
    "        f_wb = w*x[i]+b\n",
    "        cost = (f_wb-y[i])**2\n",
    "        total_cost+=cost\n",
    "    total_cost = (1/(2*m))*total_cost\n",
    "    return total_cost"
   ]
  }
 ],
